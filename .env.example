# .env file (standard format)
POSTGRES_DB=dogwalker
POSTGRES_USER=postgres

#How to generate random 32 character key
#openssl rand -hex 32
POSTGRES_PASSWORD=your-secret-key-here

# Django Security Settings for Production
DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here

# CORS Configuration for Remote Server Access
CORS_ALLOWED_ORIGINS=http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# ALLOWED_HOSTS - Updated for remote server access
ALLOWED_HOSTS=*,localhost,web